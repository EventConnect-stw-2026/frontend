# =========================================================
# Aplicación: EventConnect - Plataforma de gestión de eventos
# Archivo: .editorconfig
# Descripción:
# Configuración global del editor para mantener
# consistencia de formato y estilo en todo el proyecto.
#
# Define:
# - codificación
# - indentación
# - saltos de línea
# - espacios finales
# - estilo de comillas en TypeScript
#
# Autores:
# - Mario Caudevilla Ruiz
# - Pablo Báscones
# - Mario Hernández
# - David Borrel
# =========================================================

# =========================================================
# CONFIGURACIÓN GENERAL
# =========================================================

# Indica que este es el archivo raíz de configuración.
root = true

# =========================================================
# REGLAS GLOBALES
# =========================================================

[*]

# Codificación UTF-8.
charset = utf-8

# Indentación mediante espacios.
indent_style = space

# Tamaño de indentación.
indent_size = 2

# Inserta línea vacía al final del archivo.
insert_final_newline = true

# Elimina espacios sobrantes al final de línea.
trim_trailing_whitespace = true

# =========================================================
# CONFIGURACIÓN TYPESCRIPT
# =========================================================

[*.ts]

# Uso de comillas simples.
quote_type = single

# Configuración específica de IntelliJ
# para evitar comillas dobles.
ij_typescript_use_double_quotes = false

# =========================================================
# CONFIGURACIÓN MARKDOWN
# =========================================================

[*.md]

# Sin límite máximo de longitud de línea.
max_line_length = off

# Mantiene espacios finales en Markdown
# (útiles para saltos de línea).
trim_trailing_whitespace = false